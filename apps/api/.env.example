# ─── Entorno ───────────────────────────────────────────────────────────────────
# development | staging | production
NODE_ENV=development

# ─── Base de datos ────────────────────────────────────────────────────────────
# PostgreSQL (Neon, Railway, Supabase, local…)
DATABASE_URL=postgresql://user:password@localhost:5432/propiedad_horizontal

# ─── URLs públicas (staging / producción) ─────────────────────────────────────
# APP_BASE_URL: origen del SPA (Vercel). Enlaces en correos: ${APP_BASE_URL}/asistente/...
# Sin barra final. Obligatorio en staging/producción para convocatorias reales.
# APP_BASE_URL=https://staging.kuoro.io
#
# API_BASE_URL: origen público del API (opcional). Ej.: https://api-staging.railway.app/api/v1
# Útil para logs y herramientas; el front en Vercel usa VITE_API_BASE_URL.
# API_BASE_URL=https://api-staging.railway.app/api/v1
#
# Legado (si aún no migras): PUBLIC_APP_URL / INVITATION_APP_URL se usan como respaldo de APP_BASE_URL.
# PUBLIC_APP_URL=
# INVITATION_APP_URL=

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Orígenes permitidos del navegador (coma), sin barra final. Debe incluir APP_BASE_URL del front.
# En development sin definir → wildcard. En staging/production sin definir → se usa solo APP_BASE_URL si existe.
# ALLOWED_ORIGINS=https://staging.kuoro.io,http://localhost:5173

# ─── LiveKit ──────────────────────────────────────────────────────────────────
# https://cloud.livekit.io → Settings → Keys
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=wss://your-project.livekit.cloud

# ─── OpenAI (asistente admin / Kuoro IA) ─────────────────────────────────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Opcional — por defecto gpt-4o-mini
# OPENAI_ADMIN_ASSISTANT_MODEL=gpt-4o-mini

# ─── Resend (email) ───────────────────────────────────────────────────────────
# https://resend.com/api-keys — dominio kuoro.io verificado en Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ─── Servidor HTTP (Railway inyecta PORT) ─────────────────────────────────────
PORT=4000
HOST=0.0.0.0

# ─── Cloudflare R2 (futuro — no implementado aún) ──────────────────────────────
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_BASE_URL=
