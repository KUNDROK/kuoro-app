{
  "name": "@kuoro/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@kuoro/contracts": "0.1.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "dotenv": "^17.4.2",
    "livekit-server-sdk": "^2.15.1",
    "pg": "^8.20.0",
    "resend": "^6.11.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.4"
  }
}
